generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  DRIVER
}

enum BillStatus {
  RECEIVED
  GOODS_WITHDRAWN
  DISPATCHED
  COMPLETED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  lineUserId    String?   @unique
  role          Role      @default(DRIVER)
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  bills         Bill[]              @relation("AssignedDriver")
  statusUpdates BillStatusHistory[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Customer {
  id         String   @id @default(cuid())
  name       String
  lineUserId String?  @unique
  phone      String?
  address    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  bills Bill[]
}

model Vehicle {
  id          String   @id @default(cuid())
  plateNumber String   @unique
  type        String
  brand       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bills Bill[]
}

model Bill {
  id          String     @id @default(cuid())
  billNumber  Int        @unique @default(autoincrement())
  status      BillStatus @default(RECEIVED)
  customerId  String?
  vehicleId   String?
  driverId    String?
  origin      String?
  destination String
  description String?
  scheduledAt DateTime?
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  customer      Customer?           @relation(fields: [customerId], references: [id])
  vehicle       Vehicle?            @relation(fields: [vehicleId], references: [id])
  driver        User?               @relation("AssignedDriver", fields: [driverId], references: [id])
  statusHistory BillStatusHistory[]
  photos        DeliveryPhoto[]
}

model BillStatusHistory {
  id        String     @id @default(cuid())
  billId    String
  status    BillStatus
  note      String?
  updatedBy String?
  createdAt DateTime   @default(now())

  bill Bill  @relation(fields: [billId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [updatedBy], references: [id])
}

model DeliveryPhoto {
  id            String   @id @default(cuid())
  billId        String
  googleDriveId String
  url           String
  filename      String
  uploadedAt    DateTime @default(now())

  bill Bill @relation(fields: [billId], references: [id], onDelete: Cascade)
}
